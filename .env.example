# URL canónica (opcional en producción; por defecto https://soycontratofacil.es)
# NEXT_PUBLIC_SITE_URL=https://soycontratofacil.es

# Google Search Console → HTML tag → content value
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools → meta tag msvalidate.01 content
# NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Protege POST /api/indexnow (opcional)
# INDEXNOW_SECRET=
