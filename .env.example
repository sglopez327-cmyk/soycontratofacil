# URL canónica (debe ser el host final con www; evita “Página con redirección” en GSC)
# NEXT_PUBLIC_SITE_URL=https://www.soycontratofacil.es

# Google Search Console → HTML tag → content value
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools → meta tag msvalidate.01 content
# NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Protege POST /api/indexnow (opcional)
# INDEXNOW_SECRET=

# Google Ads (opcional): convierte pdf_generated en conversión de Ads
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXX
# NEXT_PUBLIC_GOOGLE_ADS_SEND_TO=AW-XXXXXXXXX/YYYYYYYY
